{
  "compilerOptions": {
    "types": ["vitest/globals"],
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src",
    "src/pages/allCourses/agile/Certified-Scrum-Developer-(CSD)-Certification-Training.tsx",
    "src/pages/allCourses/agile/Agile-and-Scrum-Training.tsx",
    "src/pages/allCourses/agile/Professional-Agile-Leadership-Essentials-(PAL-E)-Certification-Training.tsx",
    "src/pages/allCourses/safe/SAFe-DevOps-Certification-Training.tsx",
    "src/pages/allCourses/generativeAi/Multi-cloud-FinOps-AWS-GCP-Azure.tsx",
    "src/pages/allCourses/generativeAi/Generative-AI-for-Software-Developers-Course.tsx",
    "src/pages/allCourses/generativeAi/Generative-AI-for-Product-Owners-Product-Managers-Certification-Training.tsx",
    "src/pages/allCourses/generativeAi/Mastering-Generative-AI-Tools-Online.tsx"
  ]
}
